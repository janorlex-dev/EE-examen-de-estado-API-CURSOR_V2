# ══ NOrlexia · Test Abogacía — .gitignore ══

# Carpeta privada con credenciales, contraseñas, notas personales
.secretos/

# Variables de entorno (por si se añaden mañana)
.env
.env.local
.env.*.local

# Config local que pudiera contener secretos
config.local.js
config.local.json

# IDE / editores
.vscode/
.idea/
*.swp
*.swo

# Node (si se añaden dependencias en el futuro)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json

# Archivos del sistema
Thumbs.db
.DS_Store
desktop.ini

# Logs y temporales
*.log
*.tmp
*.bak
*.cache

# Backups de exámenes en bruto (pdf/word) — solo subimos los CSV ya procesados
/examenes/*.pdf
/examenes/*.docx
/examenes/*.doc

# Build / dist (por si en el futuro hay pipeline)
/dist/
/build/

# Documentación y chats privados (no subir al repo público)
/docs/
/Chats/
